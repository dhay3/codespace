{
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "*.py": [
      "ruff check",
      "ruff format",
      "git add"
    ],
    "*.{js,jsx,ts,tsx,css,html,sh,xml,yml,yaml,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "devDependencies": {
    "@prettier/plugin-xml": ">=3.4.2",
    "gitmoji-cli": ">=9.7.0",
    "husky": ">=9.1.7",
    "lint-staged": ">=16.2.7",
    "prettier": ">=3.8.1",
    "prettier-plugin-sh": ">=0.18.0",
    "prettier-plugin-sql": ">=0.19.2",
    "prettier-plugin-toml": ">=2.0.6"
  }
}
